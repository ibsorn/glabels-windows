# Packaging overrides appended to the CPackConfig.cmake generated by the
# upstream build.  Keeping them here rather than patching upstream CMake files
# means the source tree is used exactly as published.
#
# @TOKENS@ are substituted by the workflow before this file is appended.

# --- Naming -----------------------------------------------------------------
set(CPACK_PACKAGE_NAME "gLabels")
set(CPACK_PACKAGE_VERSION "@GLABELS_VERSION@")
set(CPACK_PACKAGE_FILE_NAME "gLabels-@GLABELS_VERSION@-win64")
set(CPACK_PACKAGE_VERSION_TWEAK "")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "gLabels 4")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "gLabels 4 Label Designer")
set(CPACK_PACKAGE_HOMEPAGE_URL "https://glabels.org")
set(CPACK_PACKAGE_VENDOR "glabels.org")

# --- NSIS installer ---------------------------------------------------------
set(CPACK_NSIS_PACKAGE_NAME "gLabels 4")
set(CPACK_NSIS_DISPLAY_NAME "gLabels 4 Label Designer")
set(CPACK_NSIS_INSTALLED_ICON_NAME "bin\\glabels-qt.exe")
set(CPACK_NSIS_HELP_LINK "https://glabels.org")
set(CPACK_NSIS_URL_INFO_ABOUT "@REPO_URL@")
set(CPACK_NSIS_CONTACT "@REPO_URL@/issues")
set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
set(CPACK_NSIS_MANIFEST_DPI_AWARE ON)

# Register the .glabels project files with the installed application.
# NSIS single-quoted strings are used so that only backslashes need escaping
# for CMake; the double quotes below survive into the generated .nsi verbatim.
set(CPACK_NSIS_EXTRA_INSTALL_COMMANDS "
  WriteRegStr HKCR '.glabels' '' 'gLabels.Project'
  WriteRegStr HKCR 'gLabels.Project' '' 'gLabels Project'
  WriteRegStr HKCR 'gLabels.Project\\DefaultIcon' '' '$INSTDIR\\bin\\glabels-qt.exe,0'
  WriteRegStr HKCR 'gLabels.Project\\shell\\open\\command' '' '\"$INSTDIR\\bin\\glabels-qt.exe\" \"%1\"'
  System::Call 'shell32::SHChangeNotify(i 0x08000000, i 0, i 0, i 0)'
")

set(CPACK_NSIS_EXTRA_UNINSTALL_COMMANDS "
  DeleteRegKey HKCR 'gLabels.Project'
  DeleteRegKey HKCR '.glabels'
  System::Call 'shell32::SHChangeNotify(i 0x08000000, i 0, i 0, i 0)'
")
